generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── AUTH ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  DIRECTORA
  CONSULTORA
}

model User {
  id          String   @id @default(cuid())
  supabaseId  String?  @unique
  name        String
  email       String   @unique
  role        Role     @default(CONSULTORA)
  parentId    String?  // replaces directoraId — any user can have children
  avatar      String?
  phone       String?
  mkNumber    String?
  commission  Decimal? @db.Decimal(5, 2)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   User?  @relation("UserHierarchy", fields: [parentId], references: [id])
  children User[] @relation("UserHierarchy")

  inventoryItems  InventoryItem[]
  clients         Client[]
  sales           Sale[]
  productRequests ProductRequest[]
  followUps       FollowUp[]
  goalsAsTarget   Goal[]           @relation("GoalTarget")
  goalsAsDirector Goal[]           @relation("GoalDirectora")
  priceOverrides  ConsultantPrice[]

  creationRequests UserCreationRequest[] @relation("RequestedBy")
  childRequests    UserCreationRequest[] @relation("RequestParent")

  @@index([parentId])
  @@index([supabaseId])
}

enum UserCreationStatus {
  PENDING
  APPROVED
  REJECTED
}

model UserCreationRequest {
  id          String             @id @default(cuid())
  requesterId String?
  name        String
  email       String
  phone       String?
  role        Role               @default(CONSULTORA)
  parentId    String?
  notes       String?
  status      UserCreationStatus @default(PENDING)
  reviewNote  String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  requester User?  @relation("RequestedBy", fields: [requesterId], references: [id], onDelete: SetNull)
  parent    User? @relation("RequestParent", fields: [parentId], references: [id])

  @@index([requesterId])
  @@index([status])
}

// ─── PRODUCTS ────────────────────────────────────────────────────────────────

model Product {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String?  @db.Text
  category     String
  subcategory  String?
  basePrice    Decimal  @default(0) @db.Decimal(10, 2)
  images       String[]
  ingredients  String?  @db.Text
  benefits     String?  @db.Text
  howItWorks   String?  @db.Text
  howToUse     String?  @db.Text
  generalInfo  String?  @db.Text
  mkUrl        String?
  sku          String?
  active       Boolean  @default(true)
  discontinued Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  inventoryItems  InventoryItem[]
  saleItems       SaleItem[]
  productRequests ProductRequest[]
  priceOverrides  ConsultantPrice[]

  @@index([category])
  @@index([slug])
}

model ConsultantPrice {
  id        String   @id @default(cuid())
  userId    String
  productId String
  salePrice Decimal  @db.Decimal(10, 2)
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

// ─── INVENTORY ───────────────────────────────────────────────────────────────

model InventoryItem {
  id             String   @id @default(cuid())
  userId         String
  productId      String
  quantity       Int      @default(0)
  alertThreshold Int      @default(2)
  updatedAt      DateTime @updatedAt

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  movements InventoryMovement[]

  @@unique([userId, productId])
  @@index([userId])
}

enum MovementType {
  IN
  OUT
  ADJUST
}

model InventoryMovement {
  id              String       @id @default(cuid())
  inventoryItemId String
  type            MovementType
  quantity        Int
  reason          String?
  createdAt       DateTime     @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@index([inventoryItemId])
}

// ─── CLIENTS ─────────────────────────────────────────────────────────────────

model Client {
  id        String    @id @default(cuid())
  userId    String
  name      String
  phone     String?
  email     String?
  birthday  DateTime?
  address   String?
  skinType  String?
  notes     String?   @db.Text
  source    String?
  tags      String[]
  avatar    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  sales     Sale[]
  followUps FollowUp[]

  @@index([userId])
  @@index([phone])
}

// ─── SALES ───────────────────────────────────────────────────────────────────

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  CREDIT
}

enum SaleStatus {
  PENDING
  PAID
  DELIVERED
  CANCELLED
}

enum SaleSourceType {
  MANUAL
  LINK_REQUEST
}

model Sale {
  id            String         @id @default(cuid())
  consultantId  String
  clientId      String?
  clientName    String?
  total         Decimal        @db.Decimal(10, 2)
  paidAmount    Decimal        @default(0) @db.Decimal(10, 2)
  paymentMethod PaymentMethod  @default(CASH)
  status        SaleStatus     @default(PENDING)
  notes         String?        @db.Text
  sourceType    SaleSourceType @default(MANUAL)
  requestId     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  consultant   User              @relation(fields: [consultantId], references: [id])
  client       Client?           @relation(fields: [clientId], references: [id])
  items        SaleItem[]
  installments SaleInstallment[]
  payments     SalePayment[]

  @@index([consultantId])
  @@index([createdAt])
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  productId String
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  discount  Decimal @default(0) @db.Decimal(10, 2)
  subtotal  Decimal @db.Decimal(10, 2)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([saleId])
}

// ─── PRODUCT REQUESTS (desde link público) ───────────────────────────────────

enum RequestStatus {
  PENDING
  CONTACTED
  SOLD
  DISMISSED
}

model ProductRequest {
  id           String        @id @default(cuid())
  productId    String
  consultantId String
  clientName   String
  clientPhone  String?
  message      String?       @db.Text
  quantity     Int           @default(1)
  status       RequestStatus @default(PENDING)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  product    Product @relation(fields: [productId], references: [id])
  consultant User    @relation(fields: [consultantId], references: [id])

  @@index([consultantId])
  @@index([status])
}

// ─── PUBLIC LINKS ────────────────────────────────────────────────────────────

model PublicLink {
  id           String   @id @default(cuid())
  consultantId String
  productId    String
  slug         String   @unique
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([consultantId])
  @@index([slug])
}

// ─── FOLLOW-UPS ──────────────────────────────────────────────────────────────

enum FollowUpType {
  CALL
  WHATSAPP
  VISIT
  DELIVERY
  POST_SALE
  BIRTHDAY
  PAYMENT
  OTHER
}

enum FollowUpStatus {
  PENDING
  DONE
}

model FollowUp {
  id                String           @id @default(cuid())
  consultantId      String
  clientId          String?
  type              FollowUpType     @default(OTHER)
  scheduledDate     DateTime
  note              String?          @db.Text
  status            FollowUpStatus   @default(PENDING)
  resultNote        String?          @db.Text
  saleInstallmentId String?          @unique
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  consultant      User             @relation(fields: [consultantId], references: [id])
  client          Client?          @relation(fields: [clientId], references: [id])
  saleInstallment SaleInstallment? @relation(fields: [saleInstallmentId], references: [id], onDelete: SetNull)

  @@index([consultantId])
  @@index([scheduledDate])
  @@index([status])
}

// ─── SALE INSTALLMENTS & PAYMENTS ────────────────────────────────────────────

enum InstallmentStatus {
  PENDING
  PAID
}

model SaleInstallment {
  id        String            @id @default(cuid())
  saleId    String
  number    Int
  amount    Decimal           @db.Decimal(10, 2)
  dueDate   DateTime
  status    InstallmentStatus @default(PENDING)
  createdAt DateTime          @default(now())

  sale     Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  followUp FollowUp?

  @@index([saleId])
}

model SalePayment {
  id            String        @id @default(cuid())
  saleId        String
  amount        Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod @default(CASH)
  note          String?
  createdAt     DateTime      @default(now())

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
}

// ─── GOALS ───────────────────────────────────────────────────────────────────

enum GoalType {
  SALES_AMOUNT
  NEW_CLIENTS
  PRODUCT_UNITS
  GROUP_SALES
}

enum GoalPeriod {
  WEEKLY
  MONTHLY
  QUARTERLY
}

model Goal {
  id           String     @id @default(cuid())
  directoraId  String
  targetUserId String?
  productId    String?
  type         GoalType
  period       GoalPeriod
  targetValue  Decimal    @db.Decimal(10, 2)
  description  String?
  startDate    DateTime
  endDate      DateTime
  createdAt    DateTime   @default(now())

  directora  User  @relation("GoalDirectora", fields: [directoraId], references: [id])
  targetUser User? @relation("GoalTarget", fields: [targetUserId], references: [id])

  @@index([directoraId])
  @@index([startDate, endDate])
}

// ─── SCRAPER LOG ─────────────────────────────────────────────────────────────

enum ScraperStatus {
  RUNNING
  DONE
  FAILED
}

model ScraperLog {
  id              String        @id @default(cuid())
  startedAt       DateTime      @default(now())
  finishedAt      DateTime?
  productsFound   Int?
  productsUpdated Int?
  productsCreated Int?
  errors          Int?
  errorDetails    String?       @db.Text
  status          ScraperStatus @default(RUNNING)
}
